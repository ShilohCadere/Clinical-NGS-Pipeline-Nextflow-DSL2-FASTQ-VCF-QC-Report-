nextflow.enable.dsl=2

params {
    samplesheet = "samplesheet.csv"
    reads       = "data/*_{1,2}.fastq.gz"
    ref         = "data/reference.fasta"
    outdir      = "results"
}

process {
    executor = 'local'
    container = 'ngs-pipeline:1.0'
}

profiles {
    docker {
        docker.enabled = true
    }
}